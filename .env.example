# ── Obligatoire ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET_KEY=générer_avec_openssl_rand_hex_32

# ── Application ───────────────────────────────────────────────────────────────
# URL de base du backend (utilisée pour les liens dans les emails)
APP_BASE_URL=http://localhost:8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origines autorisées pour le frontend (séparées par virgule)
# En prod : mettre l'IP ou le domaine du frontend ex: http://178.104.57.75
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Utilisé lors de l'initialisation de l'agence par défaut dans agencies.db
SMTP_USER=
SMTP_PASSWORD=
